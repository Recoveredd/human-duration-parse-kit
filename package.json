{
  "name": "human-duration-parse-kit",
  "version": "0.1.0",
  "description": "Parse short human duration strings with structured tokens and diagnostics.",
  "keywords": [
    "duration",
    "time",
    "parser",
    "milliseconds",
    "human-readable",
    "typescript",
    "browser",
    "developer-tools"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MPL-2.0",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/human-duration-parse-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/human-duration-parse-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/human-duration-parse-kit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
